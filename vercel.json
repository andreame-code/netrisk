{
  "version": 2,
  "buildCommand": "npm run build:ts",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/legacy",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/legacy/",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/legacy/index.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/legacy/landing.html",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/legacy/register.html",
      "destination": "/register",
      "permanent": false
    },
    {
      "source": "/legacy/lobby.html",
      "destination": "/lobby",
      "permanent": false
    },
    {
      "source": "/legacy/new-game.html",
      "destination": "/lobby/new",
      "permanent": false
    },
    {
      "source": "/legacy/profile.html",
      "destination": "/profile",
      "permanent": false
    },
    {
      "source": "/legacy/game.html",
      "has": [
        {
          "type": "query",
          "key": "gameId",
          "value": "(?<gameId>.+)"
        }
      ],
      "destination": "/game/:gameId",
      "permanent": false
    },
    {
      "source": "/legacy/game.html",
      "destination": "/game",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/",
      "destination": "/react/index.html"
    },
    {
      "source": "/react/:path*",
      "destination": "/react/index.html"
    },
    {
      "source": "/login",
      "destination": "/react/index.html"
    },
    {
      "source": "/register",
      "destination": "/react/index.html"
    },
    {
      "source": "/lobby",
      "destination": "/react/index.html"
    },
    {
      "source": "/lobby/new",
      "destination": "/react/index.html"
    },
    {
      "source": "/admin",
      "destination": "/react/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/react/index.html"
    },
    {
      "source": "/profile",
      "destination": "/react/index.html"
    },
    {
      "source": "/unauthorized",
      "destination": "/react/index.html"
    },
    {
      "source": "/game",
      "destination": "/react/index.html"
    },
    {
      "source": "/game/:path*",
      "destination": "/react/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scheduled-jobs",
      "schedule": "0 0 * * *"
    }
  ]
}
