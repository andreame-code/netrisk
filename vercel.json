{
  "version": 2,
  "buildCommand": "npm run build:ts",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/react/:path*",
      "destination": "/react/index.html"
    },
    {
      "source": "/login",
      "destination": "/react/index.html"
    },
    {
      "source": "/register",
      "destination": "/react/index.html"
    },
    {
      "source": "/unauthorized",
      "destination": "/react/index.html"
    },
    {
      "source": "/game",
      "destination": "/react/index.html"
    },
    {
      "source": "/game/:path*",
      "destination": "/react/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/scheduled-jobs",
      "schedule": "0 0 * * *"
    }
  ]
}
