{
  "name": "netrisk",
  "version": "0.1.0",
  "description": "NetRisk base architecture with separated frontend, backend and shared logic",
  "private": true,
  "scripts": {
    "start": "npm run build:ts && node .tsbuild/backend/server.cjs",
    "admin:grant": "npm run build:ts && node .tsbuild/scripts/grant-admin.cjs",
    "backup:data": "npm run build:ts && node .tsbuild/scripts/backup-datastore.cjs",
    "backup:check": "npm run build:ts && node .tsbuild/scripts/check-backup.cjs",
    "build:ts": "tsc -p tsconfig.json && npm run build:frontend && npm run build:react-shell && node .tsbuild/scripts/generate-supabase-schema.cjs && npm run check:ts-sources",
    "build:frontend": "node .tsbuild/scripts/sync-shared-runtime-validation-frontend.cjs && tsc -p tsconfig.frontend.json --incremental false && node .tsbuild/scripts/sync-public-assets.cjs",
    "build:react-shell": "vite build --config frontend/react-shell/vite.config.ts",
    "check:ts-sources": "node .tsbuild/scripts/check-no-js-sources.cjs",
    "dev:react-shell": "vite --config frontend/react-shell/vite.config.ts",
    "lint": "eslint \"backend/**/*.{ts,cts,mts}\" \"frontend/src/**/*.{ts,cts,mts,d.ts}\" \"frontend/react-shell/**/*.{ts,tsx,d.ts}\" \"shared/**/*.{ts,cts,mts,d.ts}\" \"scripts/**/*.{ts,cts,mts}\" \"tests/**/*.{ts,cts,mts,d.ts}\" \"api/**/*.{ts,cts,mts,d.ts}\" \"supabase/**/*.{ts,cts,mts,d.ts}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"backend/**/*.{ts,cts,mts}\" \"frontend/src/**/*.{ts,cts,mts,d.ts}\" \"frontend/react-shell/**/*.{ts,tsx,d.ts}\" \"shared/**/*.{ts,cts,mts,d.ts}\" \"scripts/**/*.{ts,cts,mts}\" \"tests/**/*.{ts,cts,mts,d.ts}\" \"api/**/*.{ts,cts,mts,d.ts}\" \"supabase/**/*.{ts,cts,mts,d.ts}\" \"*.md\" \"*.json\" \".github/workflows/*.yml\"",
    "format:check": "prettier --check \"backend/**/*.{ts,cts,mts}\" \"frontend/src/**/*.{ts,cts,mts,d.ts}\" \"frontend/react-shell/**/*.{ts,tsx,d.ts}\" \"shared/**/*.{ts,cts,mts,d.ts}\" \"scripts/**/*.{ts,cts,mts}\" \"tests/**/*.{ts,cts,mts,d.ts}\" \"api/**/*.{ts,cts,mts,d.ts}\" \"supabase/**/*.{ts,cts,mts,d.ts}\" \"*.md\" \"*.json\" \".github/workflows/*.yml\"",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json --noEmit",
    "typecheck:react-shell": "tsc -p tsconfig.react-shell.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:react": "vitest run --config frontend/react-shell/vitest.config.ts",
    "test:react:watch": "vitest --config frontend/react-shell/vitest.config.ts --watch",
    "test:theme-tokens": "node .tsbuild/scripts/check-theme-tokenization.cjs",
    "vercel:link:ci": "node .tsbuild/scripts/write-vercel-project-link.cjs",
    "vercel:env:check": "node .tsbuild/scripts/check-vercel-env-parity.cjs",
    "coverage:collect": "c8 --clean --reporter=none node .tsbuild/scripts/run-tests.cjs && c8 --clean=false --reporter=none node .tsbuild/scripts/run-gameplay-tests.cjs",
    "coverage:report": "c8 report --reporter=text-summary --reporter=json-summary --reporter=lcov",
    "coverage:check": "node .tsbuild/scripts/check-coverage-thresholds.cjs",
    "coverage": "npm run build:ts && npm run coverage:collect && npm run coverage:report",
    "test": "npm run build:ts && node .tsbuild/scripts/run-tests.cjs",
    "test:e2e": "npm run build:ts && node .tsbuild/scripts/run-e2e.cjs",
    "test:e2e:headed": "npm run build:ts && node .tsbuild/scripts/run-e2e.cjs --headed",
    "test:e2e:split": "npm run build:ts && node .tsbuild/scripts/run-e2e-default.cjs",
    "test:e2e:parallel": "npm run build:ts && node .tsbuild/scripts/run-e2e-default.cjs",
    "test:e2e:serial": "npm run build:ts && node .tsbuild/scripts/run-e2e.cjs",
    "test:e2e:smoke": "npm run build:ts && node .tsbuild/scripts/run-e2e.cjs e2e/smoke",
    "test:e2e:update": "npm run build:ts && node .tsbuild/scripts/run-e2e.cjs --update-snapshots",
    "test:gameplay": "npm run build:ts && node .tsbuild/scripts/run-gameplay-tests.cjs",
    "test:all": "npm run build:ts && npm run test:react && node .tsbuild/scripts/run-tests.cjs && node .tsbuild/scripts/run-gameplay-tests.cjs",
    "test:all:e2e": "npm run build:ts && npm run test:react && node .tsbuild/scripts/run-tests.cjs && node .tsbuild/scripts/run-gameplay-tests.cjs && node .tsbuild/scripts/run-e2e.cjs",
    "test:all:e2e:split": "npm run build:ts && npm run test:react && node .tsbuild/scripts/run-tests.cjs && node .tsbuild/scripts/run-gameplay-tests.cjs && npm run test:e2e:split"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@sentry/react": "^10.22.0",
    "@tanstack/react-query": "^5.99.2",
    "@vercel/speed-insights": "^2.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
