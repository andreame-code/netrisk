{
  "name": "netrisk",
  "version": "1.0.0",
  "description": "Simple browser-based Risk-inspired game",
  "scripts": {
    "lint": "eslint .",
    "start": "npm run build && node server.js",
    "dev": "vite --config config/vite.config.js",
    "build": "vite build --config config/vite.config.js",
    "preview": "vite preview --config config/vite.config.js",
    "server": "node src/multiplayer-server.js",
    "simulate": "node src/simulate.js",
    "test": "jest --config config/jest.config.js",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test:uat": "playwright test -c config/playwright.config.ts",
    "pretest:e2e:smoke": "npm run generate-env && PLAYWRIGHT_DOWNLOAD_HOST=https://playwright.download.prss.microsoft.com/dbazure/download/playwright npx playwright install chromium",
    "pretest:e2e:full": "npm run generate-env && PLAYWRIGHT_DOWNLOAD_HOST=https://playwright.download.prss.microsoft.com/dbazure/download/playwright npx playwright install chromium",
    "test:e2e:smoke": "playwright test -c config/playwright.smoke.config.ts",
    "test:e2e:full": "playwright test -c config/playwright.full.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:smoke": "jest --config config/jest.config.js tests/smoke",
    "prepare": "husky",
    "generate-env": "node scripts/generate-env.js",
    "predev": "npm run generate-env",
    "prestart": "npm run generate-env",
    "prebuild": "npm run generate-env",
    "prepreview": "npm run generate-env",
    "pretest": "npm run generate-env",
    "pretest:uat": "npm run generate-env",
    "postbuild": "npm run generate-env"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/dom": "^10.4.1",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "ajv": "^8.17.1",
    "babel-jest": "^30.1.1",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jest": "^30.1.1",
    "jest-environment-jsdom": "^30.1.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "vite": "^7.1.5",
    "ws": "^8.17.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.1",
    "bcryptjs": "^3.0.2",
    "zod": "^4.1.5"
  }
}
