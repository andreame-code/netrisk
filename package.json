{
  "name": "netrisk",
  "version": "0.1.0",
  "description": "NetRisk base architecture with separated frontend, backend and shared logic",
  "private": true,
  "scripts": {
    "start": "node backend/server.cjs",
    "backup:data": "node scripts/backup-datastore.cjs",
    "backup:check": "node scripts/check-backup.cjs",
    "vercel:env:check": "node scripts/check-vercel-env-parity.cjs",
    "test": "node scripts/run-tests.cjs",
    "test:e2e": "node scripts/run-e2e.cjs",
    "test:e2e:remote": "node scripts/run-remote-e2e.cjs",
    "test:e2e:update": "node scripts/run-e2e.cjs --update-snapshots",
    "test:gameplay": "node scripts/run-gameplay-tests.cjs",
    "test:all": "npm run test && npm run test:gameplay",
    "test:all:e2e": "npm run test && npm run test:gameplay && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0"
  }
}
