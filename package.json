{
  "name": "netrisk",
  "version": "0.1.0",
  "description": "NetRisk base architecture with separated frontend, backend and shared logic",
  "private": true,
  "scripts": {
    "start": "npm run build:ts && node .tsbuild/backend/server.cjs",
    "backup:data": "node .tsbuild/scripts/backup-datastore.cjs",
    "backup:check": "node .tsbuild/scripts/check-backup.cjs",
    "build:ts": "tsc -p tsconfig.json && npm run build:frontend && node .tsbuild/scripts/generate-supabase-schema.cjs && npm run check:ts-sources",
    "build:frontend": "tsc -p tsconfig.frontend.json && node .tsbuild/scripts/sync-frontend-imports.cjs && node .tsbuild/scripts/generate-frontend-static.cjs && node .tsbuild/scripts/sync-public-assets.cjs",
    "check:ts-sources": "node .tsbuild/scripts/check-no-js-sources.cjs",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:theme-tokens": "node .tsbuild/scripts/check-theme-tokenization.cjs",
    "vercel:env:check": "node .tsbuild/scripts/check-vercel-env-parity.cjs",
    "coverage:collect": "c8 --clean --reporter=none node .tsbuild/scripts/run-tests.cjs && c8 --clean=false --reporter=none node .tsbuild/scripts/run-gameplay-tests.cjs",
    "coverage:report": "c8 report --reporter=text-summary --reporter=json-summary --reporter=lcov",
    "coverage": "npm run build:ts && npm run coverage:collect && npm run coverage:report",
    "test": "npm run build:ts && node .tsbuild/scripts/run-tests.cjs",
    "test:e2e": "node .tsbuild/scripts/run-e2e.cjs",
    "test:e2e:headed": "node .tsbuild/scripts/run-e2e.cjs --headed",
    "test:e2e:parallel": "node .tsbuild/scripts/run-e2e-default.cjs",
    "test:e2e:serial": "node .tsbuild/scripts/run-e2e.cjs",
    "test:e2e:smoke": "node .tsbuild/scripts/run-e2e.cjs e2e/smoke",
    "test:e2e:update": "node .tsbuild/scripts/run-e2e.cjs --update-snapshots",
    "test:gameplay": "npm run build:ts && node .tsbuild/scripts/run-gameplay-tests.cjs",
    "test:all": "npm run build:ts && node .tsbuild/scripts/run-tests.cjs && node .tsbuild/scripts/run-gameplay-tests.cjs",
    "test:all:e2e": "npm run build:ts && node .tsbuild/scripts/run-tests.cjs && node .tsbuild/scripts/run-gameplay-tests.cjs && node .tsbuild/scripts/run-e2e.cjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "c8": "^11.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0"
  },
  "license": "MIT"
}
