# .env.example - Template per le variabili d'ambiente
# Copia questo file in .env.local e inserisci i tuoi valori

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# WebSocket Configuration (opzionale)
VITE_WS_URL=ws://localhost:8081

# Logging Level (opzionale)
# Options: debug, info, warn, error
VITE_LOG_LEVEL=debug

# Feature Flags (opzionale)
VITE_ENABLE_DEBUG=true

# Per ottenere le credenziali Supabase:
# 1. Vai su https://supabase.com/dashboard
# 2. Seleziona il tuo progetto
# 3. Settings → API
# 4. Copia Project URL e anon/public key
