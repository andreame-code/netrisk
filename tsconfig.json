{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "allowJs": false,
    "checkJs": false,
    "declaration": true,
    "incremental": true,
    "outDir": ".tsbuild",
    "rootDir": ".",
    "lib": ["ES2022"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "backend/**/*",
    "api/**/*",
    "modules/**/*.cts",
    "shared/**/*",
    "scripts/**/*",
    "supabase/**/*.cts",
    "tests/gameplay/**/*"
  ],
  "exclude": [
    "node_modules",
    "frontend",
    "e2e",
    ".git",
    ".tsbuild",
    "public",
    "playwright-report",
    "test-results",
    "data"
  ]
}
