{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://netrisk.example.com/schemas/map-schema.json",
  "title": "NetRisk Map",
  "type": "object",
  "required": ["schemaVersion", "territories", "continents", "deck"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "territories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "neighbors", "x", "y"],
        "properties": {
          "id": { "type": "string" },
          "neighbors": { "type": "array", "items": { "type": "string" } },
          "x": { "type": "number" },
          "y": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "continents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "territories", "bonus"],
        "properties": {
          "name": { "type": "string" },
          "territories": {
            "type": "array",
            "items": { "type": "string" }
          },
          "bonus": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "deck": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["territory", "type"],
        "properties": {
          "territory": { "type": "string" },
          "type": { "enum": ["infantry", "cavalry", "artillery"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
