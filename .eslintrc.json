{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {},
  "overrides": [
    {
      "files": ["**/*.test.js"],
      "env": { "jest": true }
    },
    {
      "files": ["e2e/**/*.spec.js"],
      "env": { "jest": true }
    }
  ]
}
