{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "allowJs": false,
    "checkJs": false,
    "noEmitOnError": true,
    "incremental": true,
    "outDir": "./public",
    "rootDir": "./frontend/src",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "frontend/src/core/**/*",
    "frontend/src/generated/shared-runtime-validation.mts",
    "frontend/src/global.d.ts",
    "frontend/src/i18n.mts",
    "frontend/src/locales/**/*"
  ],
  "exclude": ["node_modules", "frontend/.tsbuild", "public"]
}
